8:{"metadata":[["$","title","0",{"children":"Who needs MATH? | moon-math.online"}],["$","meta","1",{"name":"description","content":"I always hear people complain: \"Oh, they made us study MATH in school, even though we're never going to use it in our daily lives…\" — as though I'm supposed to "}],["$","meta","2",{"property":"og:title","content":"Who needs MATH?"}],["$","meta","3",{"property":"og:description","content":"I always hear people complain: \"Oh, they made us study MATH in school, even though we're never going to use it in our daily lives…\" — as though I'm supposed to "}],["$","meta","4",{"property":"og:image","content":"https://moon-math.online/uploads/articles/1773955532581.jpg"}],["$","meta","5",{"property":"og:image:width","content":"1200"}],["$","meta","6",{"property":"og:image:height","content":"630"}],["$","meta","7",{"property":"og:type","content":"article"}],["$","meta","8",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","9",{"name":"twitter:title","content":"Who needs MATH?"}],["$","meta","10",{"name":"twitter:description","content":"I always hear people complain: \"Oh, they made us study MATH in school, even though we're never going to use it in our daily lives…\" — as though I'm supposed to "}],["$","meta","11",{"name":"twitter:image","content":"https://moon-math.online/uploads/articles/1773955532581.jpg"}]],"error":null,"digest":"$undefined"}
