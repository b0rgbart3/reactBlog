["$","span","0",{"className":"vlist","style":{"height":"1.3214em"},"children":[["$","span","0",{"style":{"top":"-2.314em"},"children":[["$","span","0",{"className":"pstrut","style":{"height":"3em"},"children":"$undefined"}],["$","span","1",{"className":"mord","children":["$","span",null,{"className":"mord","children":[["$","span","0",{"className":"mord","children":"2"}],["$","span","1",{"className":"msupsub","children":["$","span",null,{"className":"vlist-t","children":["$","span",null,{"className":"vlist-r","children":["$","span",null,{"className":"vlist","style":{"height":"0.7507em"},"children":["$","span",null,{"style":{"top":"-2.989em","marginRight":"0.05em"},"children":[["$","span","0",{"className":"pstrut","style":{"height":"2.7em"},"children":"$undefined"}],["$","span","1",{"className":"sizing reset-size6 size3 mtight","children":["$","span",null,{"className":"mord mathnormal mtight","children":"i"}]}]]}]}]}]}]}]]}]}]]}],["$","span","1",{"style":{"top":"-3.23em"},"children":[["$","span","0",{"className":"pstrut","style":{"height":"3em"},"children":"$undefined"}],["$","span","1",{"className":"frac-line","style":{"borderBottomWidth":"0.04em"},"children":"$undefined"}]]}],"$L3e"]}],"$L3f"]}],"$L40"]}]}],"$L41"]}],"$L42"]}]]}]]}]]}]}]}]
28:["$","p","17",{"children":[["$","br","0",{"children":"$undefined"}],"What's the difference? Does this nerdy little detail even matter? Trying to wrap my brain around the math led me to a deeper understanding of the implementation -- and that revealed an extremely important and clever mechanism that actually is at the core of how Bitcoin actually works - and enforces consensus."]}]
29:["$","h2","18",{"children":[["$","br","0",{"children":"$undefined"}],"How it is implemented in the code"]}]
2a:["$","p","19",{"children":"In the code, the calculations are derived using satoshis. The bitcoin code works in whole satoshis, and Satoshi chose to only use integer math. There are no decimals or fractions of a satoshi. If you calculate the block subsidy using BTC (Bitcoins) - even by the third epoch you would arrive at a fractional number (12.5) - and the fractions get even smaller from there. 6.125, 3.0625, etc. These fractions require floating point math to calculate. And Satoshi very intentionally chose to avoid using floating point math. Satoshi intentionally chose to avoid using floating point math because different computer systems notoriously calculate floating point math differently, so Satoshi chose to simplify the calculations using integer math only — in order to guarantee consensus among a broad distributed network."}]
2b:["$","p","20",{"children":["So the starting subsidy (block reward) was 50 BTC - but in the code it is calculated in sats -- which is 5,000,000,000 (5 Billion) sats per block. ",["$","br","1",{"children":"$undefined"}],["$","br","2",{"children":"$undefined"}],"In the code, it looks like this:"]}]
2c:["$","p","21",{"children":"• COIN = 100,000,000 (100 million sats)"}]
2d:["$","p","22",{"children":"• subsidy = 50 * COIN"}]
2e:["$","p","23",{"children":"• subsidy >>= halvings"}]
