8:{"metadata":[["$","title","0",{"children":"The Mystery behind the Golden Bitcoin | moon-math.online"}],["$","meta","1",{"name":"description","content":"Whenever you read an article about Bitcoin, you see an image of these \"gold coins\" with the Bitcoin logo on the face of the coin. It's everywhere. They're even "}],["$","meta","2",{"property":"og:title","content":"The Mystery behind the Golden Bitcoin"}],["$","meta","3",{"property":"og:description","content":"Whenever you read an article about Bitcoin, you see an image of these \"gold coins\" with the Bitcoin logo on the face of the coin. It's everywhere. They're even "}],["$","meta","4",{"property":"og:image","content":"https://moon-math.online/uploads/articles/1773952400420.png"}],["$","meta","5",{"property":"og:image:width","content":"1200"}],["$","meta","6",{"property":"og:image:height","content":"630"}],["$","meta","7",{"property":"og:type","content":"article"}],["$","meta","8",{"name":"twitter:card","content":"summary_large_image"}],["$","meta","9",{"name":"twitter:title","content":"The Mystery behind the Golden Bitcoin"}],["$","meta","10",{"name":"twitter:description","content":"Whenever you read an article about Bitcoin, you see an image of these \"gold coins\" with the Bitcoin logo on the face of the coin. It's everywhere. They're even "}],["$","meta","11",{"name":"twitter:image","content":"https://moon-math.online/uploads/articles/1773952400420.png"}]],"error":null,"digest":"$undefined"}
